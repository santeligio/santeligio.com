---
import Base from '../layouts/Base.astro';
---

<Base title="Pagina non trovata">
  <section class="mx-auto max-w-2xl px-4 py-24 text-center">
    <h1 class="font-serif text-4xl text-ink-900">Pagina non trovata</h1>
    <p class="mt-4 text-ink-700">
      La pagina che cercate non esiste più o è stata spostata.
    </p>
    <a
      class="mt-8 inline-block rounded bg-wine-700 px-6 py-3 font-medium text-parchment-50 transition hover:bg-wine-800"
      href="/"
    >
      Torna alla home
    </a>
  </section>
</Base>
